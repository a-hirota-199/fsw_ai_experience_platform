# LLM provider: mock | anthropic | gemini   (Sprint 0 は mock)
LLM_PROVIDER=mock

# frontend → backend の接続先
BACKEND_URL=http://localhost:8000

# Anthropic API キー（LLM_PROVIDER=anthropic の時に必要; BYOK）
ANTHROPIC_API_KEY=

# 使用モデル（既定: claude-opus-4-8 / 最も高性能を試すなら claude-fable-5）
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini（LLM_PROVIDER=gemini の時に必要; BYOK）
# GEMINI_API_KEY か GOOGLE_API_KEY のどちらかでよい
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
