# LLM provider: mock | anthropic | gemini   (Sprint 0 は mock)
LLM_PROVIDER=mock

# frontend → backend の接続先
BACKEND_URL=http://localhost:8000

# Anthropic API キー（LLM_PROVIDER=anthropic の時に必要; BYOK）
ANTHROPIC_API_KEY=

# 使用モデル（既定: claude-opus-4-8 / 最も高性能を試すなら claude-fable-5）
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini（LLM_PROVIDER=gemini の時に必要; BYOK）
# GEMINI_API_KEY か GOOGLE_API_KEY のどちらかでよい
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GitHub 公開先 provider: mock | github   (既定は mock = 実接続しない)
GITHUB_PROVIDER=mock

# 実GitHubに公開する時に必要（GITHUB_PROVIDER=github; BYOK）
# PAT は repo スコープ（fine-grained なら contents:write + pull_requests:write）
GITHUB_TOKEN=
# 公開先の既存リポジトリ（owner/name 形式; サンドボックス想定）
GITHUB_REPO=
# GitHub Enterprise を使う場合のみ設定（未設定なら api.github.com）。空文字でもOK。
# GITHUB_API=https://github.example.com/api/v3
